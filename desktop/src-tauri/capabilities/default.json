{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:path:allow-resolve-directory",
    "opener:default",
    "shell:allow-execute",
    "shell:allow-kill",
    {
      "identifier": "shell:allow-spawn",
      "allow": [
        {
          "name": "binaries/netsgo",
          "sidecar": true,
          "args": [
            "client",
            "--server",
            {
              "validator": "https?://.+"
            },
            "--key",
            {
              "validator": ".+"
            },
            "--data-dir",
            {
              "validator": ".+"
            }
          ]
        }
      ]
    }
  ]
}
